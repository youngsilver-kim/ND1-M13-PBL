<?xml version="1.0"?>
<sdf version="1.9">
  <world name="friction_test">

    <physics type="dart">
      <max_step_size>0.001</max_step_size>
      <real_time_factor>1.0</real_time_factor>
      <real_time_update_rate>1000</real_time_update_rate>
    </physics>

    <gravity>0 0 -9.81</gravity>

    <!-- Camera view -->
    <gui fullscreen="0">
      <camera name="user_camera">
        <pose>0 -8 5 0 0.55 1.5708</pose>
        <view_controller>orbit</view_controller>
      </camera>
    </gui>

    <!-- Inclined plane: friction test surface -->
    <!-- 실험 1에서 mu/mu2 값을 0.1 / 0.5 / 1.0으로 변경 -->
    <model name="friction_slope">
      <static>true</static>
      <pose>0 0 0 0 0.2618 0</pose>

      <link name="slope_link">
        <collision name="slope_collision">
          <geometry>
            <box>
              <size>8.0 2.0 0.1</size>
            </box>
          </geometry>

          <surface>
            <friction>
              <ode>
                <mu>1.0</mu>
                <mu2>1.0</mu2>
                <slip1>0.0</slip1>
                <slip2>0.0</slip2>
              </ode>
            </friction>
            <contact>
              <ode>
                <kp>1e6</kp>
                <kd>100</kd>
              </ode>
            </contact>
          </surface>
        </collision>

        <visual name="slope_visual">
          <geometry>
            <box>
              <size>8.0 2.0 0.1</size>
            </box>
          </geometry>
          <material>
            <ambient>0.75 0.75 0.75 1</ambient>
            <diffuse>0.75 0.75 0.75 1</diffuse>
          </material>
        </visual>
      </link>
    </model>

    <!-- Sliding box -->
    <model name="sliding_box">
      <static>false</static>
      <pose>-2.8 0 1.0 0 0.2618 0</pose>

      <link name="box_link">
        <inertial>
          <mass>1.0</mass>
          <inertia>
            <ixx>0.0417</ixx>
            <iyy>0.0417</iyy>
            <izz>0.0417</izz>
            <ixy>0.0</ixy>
            <ixz>0.0</ixz>
            <iyz>0.0</iyz>
          </inertia>
        </inertial>

        <collision name="box_collision">
          <geometry>
            <box>
              <size>0.5 0.5 0.5</size>
            </box>
          </geometry>

          <surface>
            <friction>
              <ode>
                <mu>1.0</mu>
                <mu2>1.0</mu2>
                <slip1>0.0</slip1>
                <slip2>0.0</slip2>
              </ode>
            </friction>
            <contact>
              <ode>
                <kp>1e6</kp>
                <kd>100</kd>
              </ode>
            </contact>
          </surface>
        </collision>

        <visual name="box_visual">
          <geometry>
            <box>
              <size>0.5 0.5 0.5</size>
            </box>
          </geometry>
          <material>
            <ambient>0.1 0.3 1.0 1</ambient>
            <diffuse>0.1 0.3 1.0 1</diffuse>
          </material>
        </visual>
      </link>
    </model>

    <!-- Ground plane under the slope -->
    <model name="ground_plane">
      <static>true</static>
      <pose>0 0 -0.2 0 0 0</pose>
      <link name="ground_link">
        <collision name="ground_collision">
          <geometry>
            <plane>
              <normal>0 0 1</normal>
              <size>50 50</size>
            </plane>
          </geometry>
        </collision>
        <visual name="ground_visual">
          <geometry>
            <plane>
              <normal>0 0 1</normal>
              <size>50 50</size>
            </plane>
          </geometry>
          <material>
            <ambient>0.9 0.9 0.9 1</ambient>
            <diffuse>0.9 0.9 0.9 1</diffuse>
          </material>
        </visual>
      </link>
    </model>

    <light name="sun" type="directional">
      <pose>0 0 10 0 0 0</pose>
      <direction>-0.5 0.1 -0.9</direction>
      <diffuse>1 1 1 1</diffuse>
      <specular>0.1 0.1 0.1 1</specular>
      <cast_shadows>true</cast_shadows>
    </light>

  </world>
</sdf>